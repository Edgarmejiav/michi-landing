---
---
<section id="reservar" class="relative py-32 lg:py-40 overflow-hidden">
  <!-- Background with atmospheric image -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1559305616-3f99cd43e353?auto=format&fit=crop&w=1920&q=60" 
      alt="" 
      class="w-full h-full object-cover opacity-15"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-mocha/85"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-mocha via-mocha/50 to-mocha"></div>
  </div>

  <div class="container mx-auto max-w-4xl px-6 lg:px-10 relative z-10">
    <div class="book-card text-center space-y-10">
      <!-- Ornamental top -->
      <div class="flex items-center justify-center gap-4">
        <div class="w-20 h-px bg-gradient-to-r from-transparent to-accent/20"></div>
        <svg class="w-5 h-5 text-accent/30" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10 0 C5 5 0 10 10 20 C20 10 15 5 10 0Z"/>
        </svg>
        <div class="w-20 h-px bg-gradient-to-l from-transparent to-accent/20"></div>
      </div>

      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-display italic text-cream tracking-wide">
        Reserva tu Mesa
      </h2>

      <p class="text-sm text-cream/30 max-w-lg mx-auto leading-relaxed font-light">
        Aparta tu espacio en Michi Café y déjate envolver por la calidez de nuestro ambiente, 
        el aroma de café recién tostado y la compañía de nuestros michis.
      </p>

      <!-- Reservation CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-5 pt-4">
        <a 
          href="https://wa.me/51976622179?text=Hola%20Michi%20Café%2C%20quiero%20reservar%20una%20mesa" 
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center gap-3 bg-accent text-mocha px-10 py-4 font-sans font-medium text-sm tracking-[0.15em] uppercase overflow-hidden transition-all duration-500 hover:shadow-[0_0_50px_rgba(229,168,169,0.25)]"
        >
          <span class="relative z-10">Crear Reservación</span>
          <svg class="w-4 h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          <div class="absolute inset-0 bg-cream scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
        </a>
      </div>

      <!-- Schedule info -->
      <div class="flex flex-wrap justify-center gap-8 pt-8">
        <div class="flex items-center gap-2 text-cream/25">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-xs tracking-wider">Lun – Dom · 9AM – 9PM</span>
        </div>
        <div class="flex items-center gap-2 text-cream/25">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span class="text-xs tracking-wider">Jr. Guillermo Urrelo 1628</span>
        </div>
      </div>

      <!-- Ornamental bottom -->
      <div class="flex items-center justify-center gap-4 pt-4">
        <div class="w-8 h-px bg-accent/10"></div>
        <div class="w-1.5 h-1.5 rounded-full bg-accent/20"></div>
        <div class="w-8 h-px bg-accent/10"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .book-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .book-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const bookObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.2 }
  );
  document.querySelectorAll('.book-card').forEach((el) => bookObserver.observe(el));
</script>
