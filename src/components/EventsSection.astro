---
---

<section id="eventos" class="relative py-32 lg:py-40 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-mocha-mid"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(229,168,169,0.03)_0%,_transparent_50%)]"></div>

  <div class="container mx-auto max-w-7xl px-6 lg:px-10 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-20 lg:mb-28">
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-display italic text-cream tracking-wide">Próximos Eventos y Actividades</h2>
      <div class="flex items-center justify-center gap-4 mt-6">
        <div class="w-16 h-px bg-gold/20"></div>
        <svg class="w-5 h-5 text-gold/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <div class="w-16 h-px bg-gold/20"></div>
      </div>
    </div>

    <!-- Event Card -->
    <div class="event-card max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-0 glass-card rounded-2xl overflow-hidden">
        <!-- Left: Event Details -->
        <div class="p-10 lg:p-14 flex flex-col justify-center order-2 lg:order-1">
          <div class="space-y-6">
            <span class="inline-block text-xs tracking-[0.3em] uppercase text-accent font-sans">Alianza Cultural</span>
            <h3 class="text-3xl sm:text-4xl font-display text-cream tracking-wide leading-tight">
              Gatos y Relatos
            </h3>
            <p class="text-sm text-cream/30 leading-relaxed font-light max-w-md">
              Asociación Cultural que promueve la lectura, escritura, literatura e investigación en Cajamarca.
            </p>
            <p class="text-sm text-cream/30 leading-relaxed font-light">
              Club de lectura · Cineclub · Recitales · Y más.
            </p>

            <!-- Event Details -->
            <div class="flex flex-wrap gap-6 pt-4">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                <span class="text-xs text-cream/40">📍 Cajamarca, Perú</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                </svg>
                <span class="text-xs text-cream/40">216 seguidores</span>
              </div>
            </div>

            <div class="pt-4">
              <a href="https://www.instagram.com/gatosyrelatos/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 bg-accent text-mocha px-8 py-3.5 font-sans font-medium text-xs tracking-[0.2em] uppercase transition-all duration-500 hover:shadow-[0_0_30px_rgba(229,168,169,0.2)] group">
                <span>@gatosyrelatos</span>
                <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Event Image -->
        <div class="relative min-h-[300px] lg:min-h-full order-1 lg:order-2">
          <img 
            src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?auto=format&fit=crop&w=900&q=80" 
            alt="Asociación Cultural Gatos y Relatos"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-mocha-light/80 via-transparent to-transparent lg:from-mocha-light/50"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-mocha-mid/60 via-transparent to-transparent"></div>
          
          <!-- Upcoming badge -->
          <div class="absolute top-6 right-6 bg-accent/90 text-mocha px-4 py-2 text-[10px] tracking-[0.2em] uppercase font-sans font-medium">
            82 posts
          </div>
        </div>
      </div>
    </div>

    <!-- Past events thumbnails -->
    <div class="mt-16 flex justify-center">
      <div class="flex items-center gap-6">
        <span class="text-[11px] tracking-[0.3em] uppercase text-cream/20 font-sans">Próximas actividades</span>
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-mocha-mid">
            <img src="https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&fit=crop&w=100&q=60" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-mocha-mid">
            <img src="https://images.unsplash.com/photo-1474932430478-367dbb6832c1?auto=format&fit=crop&w=100&q=60" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-mocha-mid">
            <img src="https://images.unsplash.com/photo-1532012197267-da84d127e765?auto=format&fit=crop&w=100&q=60" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <div class="w-10 h-10 rounded-full bg-cream/5 border-2 border-mocha-mid flex items-center justify-center text-[10px] text-cream/30">+</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .event-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .event-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const eventObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.event-card').forEach((el) => eventObserver.observe(el));
</script>
