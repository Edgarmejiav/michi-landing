---
---
<section id="experiencia" class="relative py-32 lg:py-40 overflow-hidden">
  <!-- Ambient background -->
  <div class="absolute inset-0 bg-gradient-to-b from-mocha via-mocha-light/30 to-mocha"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-accent/[0.02] rounded-full blur-[150px]"></div>

  <div class="container mx-auto max-w-7xl px-6 lg:px-10 relative z-10">
    <!-- Header -->
    <div class="text-center mb-20 lg:mb-28">
      <span class="inline-flex items-center gap-3 text-xs tracking-[0.4em] uppercase text-gold/50 font-sans font-light mb-6">
        <span class="w-8 h-px bg-gold/30"></span>
        La Experiencia
        <span class="w-8 h-px bg-gold/30"></span>
      </span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-display italic text-cream tracking-wide">¿Por qué elegirnos?</h2>
    </div>

    <!-- Feature Cards -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      <!-- Card 1: Calidad -->
      <div class="experience-card glass-card rounded-2xl p-8 lg:p-10 group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent/[0.03] rounded-full blur-[50px] group-hover:bg-accent/[0.08] transition-all duration-700"></div>
        <div class="relative z-10">
          <div class="w-14 h-14 rounded-xl bg-accent/10 flex items-center justify-center mb-8 group-hover:bg-accent/20 transition-colors duration-500">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="text-xl font-display text-cream tracking-wide mb-4">Calidad Superior</h3>
          <p class="text-sm text-cream/30 leading-relaxed font-light">
            Granos seleccionados de San Ignacio y Jaén, tostados artesanalmente. Métodos de extracción que respetan cada nota de sabor.
          </p>
          <div class="mt-8 pt-6 border-t border-cream/[0.04]">
            <span class="text-4xl font-display text-accent/30">42%</span>
            <p class="text-[11px] text-cream/20 tracking-wider uppercase mt-1">Preferencia en café de especialidad</p>
          </div>
        </div>
      </div>

      <!-- Card 2: Temática -->
      <div class="experience-card glass-card rounded-2xl p-8 lg:p-10 group relative overflow-hidden md:translate-y-8">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gold/[0.03] rounded-full blur-[50px] group-hover:bg-gold/[0.08] transition-all duration-700"></div>
        <div class="relative z-10">
          <div class="w-14 h-14 rounded-xl bg-gold/10 flex items-center justify-center mb-8 group-hover:bg-gold/20 transition-colors duration-500">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="text-xl font-display text-cream tracking-wide mb-4">Temática Felina</h3>
          <p class="text-sm text-cream/30 leading-relaxed font-light">
            Un espacio lúdico y acogedor donde cada detalle está pensado para conectar emocionalmente. Desde el arte latte hasta la decoración.
          </p>
          <div class="mt-8 pt-6 border-t border-cream/[0.04]">
            <span class="text-4xl font-display text-gold/30">🐱</span>
            <p class="text-[11px] text-cream/20 tracking-wider uppercase mt-1">Jr. Guillermo Urrelo 1628</p>
          </div>
        </div>
      </div>

      <!-- Card 3: Postres -->
      <div class="experience-card glass-card rounded-2xl p-8 lg:p-10 group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent-warm/[0.03] rounded-full blur-[50px] group-hover:bg-accent-warm/[0.08] transition-all duration-700"></div>
        <div class="relative z-10">
          <div class="w-14 h-14 rounded-xl bg-accent-warm/10 flex items-center justify-center mb-8 group-hover:bg-accent-warm/20 transition-colors duration-500">
            <svg class="w-6 h-6 text-accent-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.37c-2.032 0-4.034.126-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z" />
            </svg>
          </div>
          <h3 class="text-xl font-display text-cream tracking-wide mb-4">Dulces Artesanales</h3>
          <p class="text-sm text-cream/30 leading-relaxed font-light">
            Postres frescos elaborados con ingredientes locales. Cheesecakes, tortas y nuestras icónicas galletas Michi para completar tu visita.
          </p>
          <div class="mt-8 pt-6 border-t border-cream/[0.04]">
            <span class="text-4xl font-display text-accent-warm/30">∞</span>
            <p class="text-[11px] text-cream/20 tracking-wider uppercase mt-1">Sabores por descubrir</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .experience-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .experience-card.visible:nth-child(2) {
    transition-delay: 0.15s;
    transform: translateY(2rem);
  }
  .experience-card.visible:nth-child(3) {
    transition-delay: 0.3s;
  }
</style>

<script>
  const cardObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.experience-card').forEach((card) => cardObserver.observe(card));
</script>
