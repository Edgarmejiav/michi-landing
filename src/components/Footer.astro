---
---
<footer id="contacto" class="relative bg-mocha pt-24 pb-10 border-t border-cream/[0.04]">
  <div class="container mx-auto max-w-7xl px-6 lg:px-10">
    <h2 class="sr-only">Información de Interés</h2>
    <div class="grid md:grid-cols-4 gap-12 lg:gap-16 mb-16">
      <!-- Brand -->
      <div class="md:col-span-1 space-y-6">
        <div class="flex items-center gap-3">
          <span class="text-xl font-display tracking-[0.2em] text-cream">MICHI</span>
          <span class="w-px h-4 bg-gold/20"></span>
          <span class="text-[10px] font-sans tracking-[0.4em] text-gold/40 uppercase">Café</span>
        </div>
        <p class="text-xs text-cream/20 leading-relaxed font-light italic">
          "El rincón favorito de los gatos y el buen café en Cajamarca."
        </p>
        <!-- Social Icons -->
        <div class="flex gap-3 pt-2">
          <a href="https://www.instagram.com/michicafes/?hl=es" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Michi Café" class="w-9 h-9 rounded-full border border-cream/[0.06] flex items-center justify-center text-cream/20 hover:border-accent/30 hover:text-accent transition-all duration-300">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://facebook.com/michicafes" target="_blank" rel="noopener noreferrer" aria-label="Facebook de Michi Café" class="w-9 h-9 rounded-full border border-cream/[0.06] flex items-center justify-center text-cream/20 hover:border-accent/30 hover:text-accent transition-all duration-300">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a href="https://tiktok.com/@michicafes" target="_blank" rel="noopener noreferrer" aria-label="TikTok de Michi Café" class="w-9 h-9 rounded-full border border-cream/[0.06] flex items-center justify-center text-cream/20 hover:border-accent/30 hover:text-accent transition-all duration-300">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48v-7.15a8.16 8.16 0 005.58 2.18v-3.45a4.85 4.85 0 01-1-.1v.53z"/></svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="space-y-6">
        <h3 class="text-xs tracking-[0.3em] uppercase text-cream/40 font-sans">Navegación</h3>
        <ul class="space-y-3">
          <li><a href="#inicio" class="text-sm text-cream/20 hover:text-cream/60 transition-colors duration-300 font-light">Inicio</a></li>
          <li><a href="#menu" class="text-sm text-cream/20 hover:text-cream/60 transition-colors duration-300 font-light">Menú</a></li>
          <li><a href="#experiencia" class="text-sm text-cream/20 hover:text-cream/60 transition-colors duration-300 font-light">Experiencia</a></li>
          <li><a href="#eventos" class="text-sm text-cream/20 hover:text-cream/60 transition-colors duration-300 font-light">Eventos</a></li>
          <li><a href="/menu" class="text-sm text-cream/20 hover:text-cream/60 transition-colors duration-300 font-light">Carta Completa</a></li>
        </ul>
      </div>

      <!-- Visit -->
      <div class="space-y-6">
        <h3 class="text-xs tracking-[0.3em] uppercase text-cream/40 font-sans">Visítanos</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent/40 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <address class="not-italic text-sm text-cream/20 font-light leading-relaxed">
              <a href="https://www.google.com/maps?q=Michi+Café,+06000,+Cajamarca+06000" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors duration-300">Jr. Guillermo Urrelo 1628,<br/>Cajamarca, Perú.</a>
            </address>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-accent/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <time datetime="Mo-Su 09:00-21:00" class="text-sm text-cream/20 font-light">Lun – Dom: 9AM – 9PM</time>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-6">
        <h3 class="text-xs tracking-[0.3em] uppercase text-cream/40 font-sans">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-accent/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <span class="text-sm text-cream/20 font-light">+51 976 622 179</span>
          </li>

        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-cream/[0.04] flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-[11px] text-cream/15 tracking-wider">© 2026 Michi Café. Todos los derechos reservados.</p>
      <div class="flex gap-8">
        <a href="#" class="text-[11px] text-cream/15 hover:text-cream/40 transition-colors tracking-wider">Privacidad</a>
        <a href="#" class="text-[11px] text-cream/15 hover:text-cream/40 transition-colors tracking-wider">Términos</a>
      </div>
    </div>
  </div>
</footer>
