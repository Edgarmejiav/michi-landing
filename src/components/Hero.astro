---
---
<section id="inicio" class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- Background ambient effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-accent/5 rounded-full blur-[120px] animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 -right-32 w-80 h-80 bg-gold/5 rounded-full blur-[100px] animate-pulse-glow delay-500"></div>
  </div>

  <div class="container mx-auto max-w-7xl px-6 lg:px-10 grid lg:grid-cols-2 gap-16 lg:gap-20 items-center relative z-10">
    <!-- Left: Text Content -->
    <div class="space-y-10 py-12 lg:py-0">
      <!-- Tagline -->
      <div class="animate-fade-up">
        <span class="inline-flex items-center gap-3 text-xs tracking-[0.4em] uppercase text-gold/60 font-sans font-light">
          <span class="w-8 h-px bg-gold/40"></span>
          Café de Especialidad · Cajamarca
        </span>
      </div>

      <!-- Main heading -->
      <h1 class="animate-fade-up delay-200">
        <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-display leading-[0.95] text-cream tracking-tight">
          Mucho más
        </span>
        <span class="block text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-display leading-[0.95] mt-2">
          que <em class="text-accent italic font-serif font-light">solo café.</em>
        </span>
      </h1>

      <!-- Description -->
      <p class="text-base lg:text-lg text-cream/40 max-w-lg leading-relaxed font-light animate-fade-up delay-400">
        Disfruta de granos de origen en un ambiente diseñado para amantes de los gatos. 
        Una experiencia gourmet única en el corazón de Cajamarca.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-5 animate-fade-up delay-500">
        <a href="#menu" class="group relative inline-flex items-center gap-3 bg-accent text-mocha px-8 py-4 font-sans font-medium text-sm tracking-wider uppercase overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(229,168,169,0.25)]">
          <span class="relative z-10">Explorar Menú</span>
          <svg class="w-4 h-4 relative z-10 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          <div class="absolute inset-0 bg-cream scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
        </a>
        <a href="#experiencia" class="inline-flex items-center gap-3 border border-cream/10 px-8 py-4 font-sans text-sm tracking-wider text-cream/60 hover:text-cream hover:border-cream/30 transition-all duration-300 uppercase">
          Nuestra Historia
        </a>
      </div>

      <!-- Micro stats -->
      <div class="flex gap-10 pt-4 animate-fade-up delay-700">
        <div>
          <span class="block text-2xl font-display text-accent">4.9★</span>
          <span class="text-[11px] tracking-wider text-cream/30 uppercase">Google Reviews</span>
        </div>
        <div class="w-px bg-cream/10"></div>
        <div>
          <span class="block text-2xl font-display text-accent">100%</span>
          <span class="text-[11px] tracking-wider text-cream/30 uppercase">Granos Locales</span>
        </div>
        <div class="w-px bg-cream/10"></div>
        <div>
          <span class="block text-2xl font-display text-accent">🐱</span>
          <span class="text-[11px] tracking-wider text-cream/30 uppercase">Cat Friendly</span>
        </div>
      </div>
    </div>

    <!-- Right: Hero Image -->
    <div class="relative animate-scale-in delay-300">
      <!-- Main image container -->
      <div class="relative z-10">
        <div class="aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl shadow-black/40 relative">
          <img 
            src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1200&q=80" 
            alt="Café y macarons artesanales de Michi Café"
            class="w-full h-full object-cover"
            loading="eager"
          />
          <!-- Image overlay gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-mocha/60 via-transparent to-transparent"></div>
          
          <!-- Floating badge -->
          <div class="absolute bottom-6 left-6 right-6 glass-card rounded-2xl p-5 flex items-center gap-4">
            <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-accent/30 shrink-0">
              <img src="/Cappuccino.png" alt="Cappuccino Michi" class="w-full h-full object-cover" />
            </div>
            <div>
              <p class="text-sm font-display text-cream tracking-wide">Cappuccino Michi</p>
              <p class="text-xs text-cream/40 font-light">Arte latte con granos de San Ignacio</p>
            </div>
            <span class="ml-auto text-accent font-display text-lg">S/10</span>
          </div>
        </div>
      </div>

      <!-- Decorative Elements -->
      <div class="absolute -top-8 -right-8 w-64 h-64 border border-accent/10 rounded-full animate-spin-slow pointer-events-none"></div>
      <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-accent/5 rounded-full blur-[60px]"></div>
      
      <!-- Coffee beans scatter (SVG) -->
      <svg class="absolute -top-4 right-12 w-6 h-6 text-accent/20 animate-float" viewBox="0 0 24 24" fill="currentColor">
        <ellipse cx="12" cy="12" rx="8" ry="11" />
        <line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
      </svg>
      <svg class="absolute bottom-20 -left-6 w-4 h-4 text-gold/20 animate-float-reverse" viewBox="0 0 24 24" fill="currentColor">
        <ellipse cx="12" cy="12" rx="8" ry="11" />
      </svg>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 animate-fade-in delay-800">
    <span class="text-[10px] tracking-[0.4em] uppercase text-cream/20">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-cream/20 to-transparent"></div>
  </div>
</section>
