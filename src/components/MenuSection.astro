---
const menuRows = [
  {
    id: "clasicos",
    title: "CLÁSICOS",
    description: "Espresso, Cappuccino, Latte, Americano y más. Los esenciales de la casa preparados con granos seleccionados de Cajamarca.",
    image: "/Cappuccino.png",
    imageAlt: "Cappuccino clásico con espuma de leche",
    position: "image-left" as const,
  },
  {
    id: "especiales",
    title: "CAFÉ ESPECIALES",
    description: "Café bombón, Mochaccino, Cappuccino Caramel, Latte maracumiaw y una docena más de creaciones únicas que solo encontrarás aquí.",
    image: "/Bombon.png",
    imageAlt: "Café bombón con leche condensada",
    position: "image-right" as const,
  },
  {
    id: "frias",
    title: "BEBIDAS FRÍAS",
    description: "Affogato, Frappés, Iced latte, Citrus coffee… Refrescantes opciones para cualquier momento del día, con o sin cafeína.",
    image: "/Affogato.png",
    imageAlt: "Affogato de vainilla con espresso",
    position: "image-left" as const,
  },
  {
    id: "sandwiches",
    title: "SANDWICHES",
    description: "Panini con pollo, Triple Completo, Sandwich de Palta… Todos hechos con pan ciabatta y la opción de masa madre. ¡Tu sandwich como tú quieras!",
    image: "/Cappuccino.png",
    imageAlt: "Sandwich artesanal en pan ciabatta",
    position: "image-right" as const,
  },
  {
    id: "postres",
    title: "POSTRES",
    description: "Torta de Chocolate, Tres leches de café, Michi tiramisú, Cheesecake de maracuyá… El cierre perfecto para cualquier visita.",
    image: "/torta.png",
    imageAlt: "Torta artesanal de chocolate",
    position: "image-left" as const,
  }
];
---

<section id="menu" class="relative py-32 lg:py-40 overflow-hidden">
  <!-- Dark textured background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(28,25,23,0.4)_0%,_rgba(12,10,9,1)_70%)]"></div>

  <!-- Salt/spice scatter decorative dots -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- Right edge powder scatter -->
    <div class="absolute top-[15%] -right-4 w-60 h-[500px] opacity-20">
      <div class="absolute top-0 right-8 w-1 h-1 bg-cream/60 rounded-full"></div>
      <div class="absolute top-8 right-16 w-0.5 h-0.5 bg-cream/40 rounded-full"></div>
      <div class="absolute top-20 right-4 w-1.5 h-1.5 bg-cream/30 rounded-full"></div>
      <div class="absolute top-32 right-12 w-0.5 h-0.5 bg-cream/50 rounded-full"></div>
      <div class="absolute top-44 right-6 w-1 h-1 bg-cream/20 rounded-full"></div>
      <div class="absolute top-60 right-20 w-0.5 h-0.5 bg-cream/40 rounded-full"></div>
      <div class="absolute top-72 right-8 w-2 h-2 bg-cream/10 rounded-full blur-sm"></div>
      <div class="absolute top-[300px] right-14 w-0.5 h-0.5 bg-cream/30 rounded-full"></div>
      <div class="absolute top-[350px] right-4 w-1 h-1 bg-cream/20 rounded-full"></div>
      <div class="absolute top-[400px] right-24 w-0.5 h-0.5 bg-cream/50 rounded-full"></div>
    </div>

    <!-- Left edge herb scatter -->
    <div class="absolute top-[40%] -left-4 w-40 h-[400px] opacity-15">
      <div class="absolute top-0 left-8 w-1 h-1 bg-green-800/60 rounded-full"></div>
      <div class="absolute top-16 left-4 w-0.5 h-0.5 bg-green-900/40 rounded-full"></div>
      <div class="absolute top-28 left-12 w-1.5 h-1.5 bg-green-800/20 rounded-full"></div>
      <div class="absolute top-48 left-6 w-0.5 h-0.5 bg-green-900/30 rounded-full"></div>
    </div>

    <!-- Bottom right powder burst -->
    <div class="absolute bottom-[10%] right-[5%] w-80 h-80 opacity-[0.06]">
      <div class="absolute inset-0 bg-cream/10 rounded-full blur-3xl"></div>
    </div>
  </div>

  <div class="container mx-auto max-w-6xl px-6 lg:px-10 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-24 lg:mb-32">
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-display italic text-cream tracking-wide">Menu</h2>
      <div class="flex items-center justify-center gap-4 mt-6">
        <div class="w-16 sm:w-20 h-px bg-gradient-to-r from-transparent to-gold/30 shrink-0"></div>
        <a href="/menu" class="text-[10px] sm:text-xs tracking-[0.3em] uppercase text-gold/50 hover:text-gold transition-colors duration-300 font-sans whitespace-nowrap">Ver carta completa</a>
        <div class="w-16 sm:w-20 h-px bg-gradient-to-l from-transparent to-gold/30 shrink-0"></div>
      </div>
    </div>

    <!-- Zigzag Menu Items -->
    <div class="relative">
      <!-- Central connector line (desktop only) -->
      <div class="hidden lg:block absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-px">
        <div class="w-full h-full bg-gradient-to-b from-transparent via-accent/15 to-transparent"></div>
      </div>

      <div class="space-y-24 lg:space-y-32">
        {menuRows.map((item, index) => (
          <div class="menu-row relative" data-index={index}>
            <div class={`flex flex-col items-center gap-10 lg:gap-16 ${
              item.position === 'image-left' 
                ? 'lg:flex-row' 
                : 'lg:flex-row-reverse'
            }`}>
              
              <!-- Image -->
              <div class="w-full lg:w-1/2 flex justify-center relative">
                <div class="relative group">
                  <!-- Circular plate image -->
                  <div class="w-56 h-56 sm:w-64 sm:h-64 lg:w-72 lg:h-72 rounded-full overflow-hidden relative">
                    <img 
                      src={item.image} 
                      alt={item.imageAlt}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                      loading="lazy"
                    />
                    <!-- Subtle vignette on image -->
                    <div class="absolute inset-0 rounded-full shadow-[inset_0_0_40px_rgba(0,0,0,0.4)]"></div>
                  </div>

                  <!-- Decorative ring -->
                  <div class="absolute -inset-3 rounded-full border border-cream/[0.04] group-hover:border-accent/10 transition-colors duration-700"></div>
                  
                  <!-- Small decorative elements around plates -->
                  {index === 0 && (
                    <>
                      <div class="absolute -top-6 -right-2 w-3 h-3 rounded-full bg-red-900/30 animate-float"></div>
                      <div class="absolute top-4 -right-8 w-2 h-2 rounded-full bg-red-800/20 animate-float-reverse"></div>
                      <svg class="absolute -bottom-4 right-8 w-8 h-4 text-green-900/20 animate-float" viewBox="0 0 32 16">
                        <ellipse cx="16" cy="8" rx="14" ry="6" fill="currentColor" />
                      </svg>
                    </>
                  )}
                  {index === 1 && (
                    <>
                      <svg class="absolute -top-2 -left-6 w-5 h-5 text-green-900/25 rotate-45 animate-float" viewBox="0 0 20 20">
                        <path d="M10 0 C5 5 0 10 10 20 C20 10 15 5 10 0Z" fill="currentColor"/>
                      </svg>
                      <div class="absolute bottom-4 -right-6 w-2.5 h-2.5 rounded-full bg-amber-900/20 animate-float-reverse"></div>
                    </>
                  )}
                  {index === 2 && (
                    <>
                      <div class="absolute -top-3 left-8 w-1.5 h-1.5 rounded-full bg-cream/15 animate-float"></div>
                      <div class="absolute -top-1 left-14 w-1 h-1 rounded-full bg-cream/10"></div>
                      <div class="absolute bottom-0 -left-5 w-2 h-2 rounded-full bg-cream/10 animate-float-reverse"></div>
                      <svg class="absolute -bottom-6 left-12 w-6 h-3 text-green-900/20 -rotate-12" viewBox="0 0 24 12">
                        <ellipse cx="12" cy="6" rx="10" ry="5" fill="currentColor"/>
                      </svg>
                    </>
                  )}
                  {index === 3 && (
                    <>
                      <div class="absolute -top-4 right-4 w-3 h-3 rounded-full bg-orange-900/15 animate-float"></div>
                      <div class="absolute bottom-8 -right-6 w-1.5 h-1.5 rounded-full bg-yellow-900/20 animate-float-reverse"></div>
                    </>
                  )}
                  {index === 4 && (
                    <>
                      <div class="absolute -top-3 -left-3 w-2 h-2 rounded-full bg-amber-800/20 animate-float"></div>
                      <div class="absolute bottom-4 -right-4 w-3 h-3 rounded-full bg-red-900/15 animate-float-reverse"></div>
                    </>
                  )}
                </div>

                <!-- Connector dot on center line (desktop) -->
                <div class={`hidden lg:block absolute top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-accent/40 border border-accent/20 ${
                  item.position === 'image-left' ? '-right-[calc(50%-2rem)] lg:-right-8' : '-left-[calc(50%-2rem)] lg:-left-8'
                }`} style="display: none;"></div>
              </div>

              <!-- Text Content -->
              <div class={`w-full lg:w-1/2 space-y-5 ${
                item.position === 'image-left' ? 'lg:text-left' : 'lg:text-right'
              } text-center`}>
                <h3 class="text-2xl sm:text-3xl font-display tracking-[0.15em] text-cream">{item.title}</h3>
                <p class="text-sm leading-relaxed text-cream/35 max-w-md font-light mx-auto lg:mx-0" style={item.position === 'image-right' ? 'margin-left: auto;' : ''}>
                  {item.description}
                </p>
              </div>
            </div>

            <!-- Dashed connector between items (desktop) -->
            {index < menuRows.length - 1 && (
              <div class="hidden lg:flex justify-center mt-16">
                <div class="w-px h-12 border-l border-dashed border-cream/[0.06]"></div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Bottom flourish text -->
      <div class="text-center mt-24 lg:mt-32 space-y-6">
        <p class="text-3xl sm:text-4xl font-serif italic text-cream/20 tracking-wide">hecho con amor</p>
        <div class="flex items-center justify-center gap-4">
          <div class="w-16 h-px bg-accent/10"></div>
          <svg class="w-4 h-4 text-accent/20" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6z"/>
          </svg>
          <div class="w-16 h-px bg-accent/10"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .menu-row {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .menu-row.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.menu-row').forEach((row) => {
    observer.observe(row);
  });
</script>
