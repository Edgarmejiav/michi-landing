---

<Layout title="Nuestra Carta | Menú de Especialidades y Repostería Felina" description="Descubre todos los productos de Michi Café: cafés clásicos y especiales, infusiones, sandwiches, waffles, postres, bebidas frías y más. Café de especialidad en Cajamarca.">
  <Navbar />
  <main class="pt-32 pb-24 px-6 min-h-screen">
    <div class="container mx-auto max-w-4xl">
      <nav aria-label="Breadcrumb" class="flex justify-center mb-6">
        <ol class="flex items-center gap-2 text-xs text-stone-500">
          <li><a href="/" class="hover:text-accent transition-colors">Inicio</a></li>
          <li class="text-stone-600">/</li>
          <li class="text-stone-400" aria-current="page">Nuestra Carta</li>
        </ol>
      </nav>

      <div class="text-center mb-16 space-y-4">
        <h1 class="text-5xl md:text-6xl font-serif text-accent">Nuestra Carta | Menú de Especialidades y Repostería Felina</h1>
        <p class="text-stone-400">Café de especialidad, infusiones, sandwiches, postres y más. Conoce todo lo que Michi Café tiene para ti en Cajamarca.</p>
      </div>

      <!-- Breadcrumb structured data -->
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://michicafe.com" },
            { "@type": "ListItem", "position": 2, "name": "Nuestra Carta", "item": "https://michicafe.com/menu" }
          ]
        }
      </script>

      <div class="space-y-16">
        {menuData.map((seccion) => (
          <div class="space-y-10">
            <h2 class="text-3xl font-serif text-stone-100 border-b border-accent/20 pb-4 flex items-center gap-4">
              <span class="w-2 h-2 bg-accent rounded-full"></span>
              {seccion.h2}
            </h2>
            <div class="space-y-8">
              {seccion.subcategorias.map((sub) => (
                <div>
                  <h3 class="text-xl font-medium text-accent/90 mb-4">{sub.h3}</h3>
                  {sub.notas && (
                    <p class="text-accent/70 text-sm italic -mt-2 mb-4">{sub.notas}</p>
                  )}
                  <div class="grid md:grid-cols-2 gap-x-12 gap-y-4">
                    {sub.productos.map((item) => (
                      <div class="flex justify-between items-baseline gap-3 py-2 border-b border-white/5">
                        <div>
                          <strong class="text-stone-200">{item.nombre}</strong>
                          {item.descripcion && (
                            <span class="text-stone-400 text-sm italic ml-1">{item.descripcion}</span>
                          )}
                        </div>
                        {item.precio && <span class="text-accent font-bold whitespace-nowrap">{item.precio}</span>}
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
