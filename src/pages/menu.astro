---

<Layout title="Nuestra Carta | Michi Café" description="Descubre todos los productos de Michi Café: cafés clásicos y especiales, infusiones, sandwiches, waffles, postres, bebidas frías y más. Café de especialidad en Cajamarca.">
  <Navbar />
  <main class="pt-32 pb-24 px-6 min-h-screen">
    <div class="container mx-auto max-w-4xl">
      <nav aria-label="Breadcrumb" class="flex justify-center mb-6">
        <ol class="flex items-center gap-2 text-xs text-stone-500">
          <li><a href="/" class="hover:text-accent transition-colors">Inicio</a></li>
          <li class="text-stone-600">/</li>
          <li class="text-stone-400" aria-current="page">Nuestra Carta</li>
        </ol>
      </nav>

      <div class="text-center mb-16 space-y-4">
        <h1 class="text-5xl md:text-6xl font-serif text-accent">Nuestra Carta</h1>
        <p class="text-stone-400">Café de especialidad, infusiones, sandwiches, postres y más. Conoce todo lo que Michi Café tiene para ti en Cajamarca.</p>
      </div>

      <!-- Breadcrumb structured data -->
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://michicafe.com" },
            { "@type": "ListItem", "position": 2, "name": "Nuestra Carta", "item": "https://michicafe.com/menu" }
          ]
        }
      </script>

      <div class="space-y-16">
        {menuData.categorias.map((cat) => (
          <div class="space-y-8">
            <h2 class="text-3xl font-serif text-stone-100 border-b border-accent/20 pb-4 flex items-center gap-4">
              <span class="w-2 h-2 bg-accent rounded-full"></span>
              {cat.seccion}
            </h2>
            {cat.notas && (
              <p class="text-accent/70 text-sm italic -mt-4">{cat.notas}</p>
            )}
            <div class="grid md:grid-cols-2 gap-x-12 gap-y-8">
              {cat.productos.map((item) => (
                <div class="group border-b border-white/5 pb-6 hover:border-accent/30 transition duration-300">
                  <div class="flex justify-between items-baseline gap-3 mb-2">
                    <h3 class="text-xl font-medium text-stone-200 group-hover:text-accent transition break-words">{item.nombre}</h3>
                    <span class="text-accent font-bold">{item.precio}</span>
                  </div>
                  {item.descripcion && (
                    <p class="text-stone-400 text-sm italic">{item.descripcion}</p>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
